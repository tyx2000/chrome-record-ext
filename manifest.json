{
  "manifest_version": 3,
  "name": "TabRecorder",
  "description": "click to record the current tab, another click to stop and save",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "downloads",
    "offscreen",
    "scripting",
    "storage",
    "tabCapture"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Tab recorder"
  }
}
